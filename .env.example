GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# 32바이트 대칭키를 Base64로 인코딩한 값 (예: openssl rand -base64 32)
DATA_ENC_KEY=YOUR_32BYTE_BASE64_ENCRYPTION_KEY

# 래피드 판매 콘텐츠(비대면 상담) 링크 (프론트에서 사용)
# VITE_RAPIDO_CONTENT_URL=https://your-rapido-content-url.com
# 기존 상담 링크와 동일하면 VITE_RAPIDO_CONSULT_URL 만 설정해도 됨
# VITE_RAPIDO_CONSULT_URL=https://your-rapido-consult-url.com

